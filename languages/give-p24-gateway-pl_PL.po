msgid "Give Przelewy24"
msgstr "Give Przelewy24"

msgid "Give Przelewy24 Gateway requires the Give plugin to be active."
msgstr "Give Przelewy24 Gateway wymaga aktywnej wtyczki Give."

msgid "Plugin dependency missing"
msgstr "Brak wymaganej wtyczki"

msgid "Settings"
msgstr "Ustawienia"

msgid "Mode"
msgstr "Tryb"

msgid "Przelewy24 Settings"
msgstr "Ustawienia Przelewy24"

msgid "Configure Przelewy24 credentials for sandbox or production payments."
msgstr "Skonfiguruj dane dostępowe Przelewy24 dla płatności sandbox lub produkcyjnych."

msgid "Sandbox"
msgstr "Sandbox"

msgid "Production"
msgstr "Produkcja"

msgid "Merchant ID"
msgstr "Merchant ID"

msgid "POS ID"
msgstr "POS ID"

msgid "API key / secretId"
msgstr "Klucz API / secretId"

msgid "CRC key"
msgstr "Klucz CRC"

msgid "Test connection"
msgstr "Test połączenia"

msgid "Test Przelewy24 API access"
msgstr "Przetestuj dostęp API Przelewy24"

msgid "Connection successful."
msgstr "Połączenie poprawne."

msgid "Connection failed. Check mode, POS ID and API key / secretId."
msgstr "Połączenie nieudane. Sprawdź tryb, POS ID oraz klucz API / secretId."

msgid "required"
msgstr "wymagane"

msgid "Saved - leave blank to keep"
msgstr "Zapisano – pozostaw puste, aby zachować"

msgid "Saved. Leave as *** to keep the current key."
msgstr "Zapisano. Pozostaw *** bez zmian, aby zachować obecny klucz."

msgid "Przelewy24 settings were not saved. All Przelewy24 fields are required."
msgstr "Ustawienia Przelewy24 nie zostały zapisane. Wszystkie pola Przelewy24 są wymagane."

msgid "Przelewy24"
msgstr "Przelewy24"

msgid "You will be redirected to Przelewy24 to complete the donation."
msgstr "Zostaniesz przekierowany na stronę Przelewy24, aby sfinalizować darowiznę."

msgid "Przelewy24 gateway is not configured."
msgstr "Bramka Przelewy24 nie została skonfigurowana."

msgid "Donation #%s"
msgstr "Darowizna nr %s"

msgid "Donation - %s"
msgstr "Darowizna - %s"

msgid "Przelewy24 payment verified (transaction %s)."
msgstr "Płatność Przelewy24 została potwierdzona (transakcja %s)."

msgid "Przelewy24 payment verified."
msgstr "Płatność Przelewy24 została potwierdzona."

msgid "Przelewy24 transaction registration failed."
msgstr "Rejestracja transakcji Przelewy24 nie powiodła się."
